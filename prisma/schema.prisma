generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id                 String               @id @default(cuid())
  username           String               @unique
  passwordHash       String
  name               String
  role               Role                 @default(EMPLOYEE)
  salaryPercentage   Float                @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  percentageHistory  PercentageHistory[]
  salaryRecords      SalaryRecord[]
}

model PercentageHistory {
  id            String   @id @default(cuid())
  userId        String
  percentage    Float
  effectiveFrom DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveFrom])
}

model DailyRevenue {
  id        String   @id @default(cuid())
  date      DateTime @unique
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salaries  SalaryRecord[]
}

model SalaryRecord {
  id             String       @id @default(cuid())
  userId         String
  dailyRevenueId String
  percentageUsed Float
  salaryAmount   Float
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyRevenue   DailyRevenue @relation(fields: [dailyRevenueId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyRevenueId])
  @@index([userId])
  @@index([dailyRevenueId])
}
